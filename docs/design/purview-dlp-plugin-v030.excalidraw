    {
      "id": "flow-step-1",
      "type": "text",
      "x": 50,
      "y": 680,
      "width": 1140,
      "height": 130,
      "text": "Message Flow:\n① User sends message via Telegram → Gateway receives it\n② L3 (message_received): Purview processContent(uploadText) → logs BLOCKED or ALLOWED (audit only, cannot block delivery)\n③ L1 (before_agent_start): DLP security policy injected into LLM system context (\"never output credit cards, SSNs...\")\n④ LLM processes message with DLP policy active → refuses to echo sensitive data → responds with [Agent Warden DLP] notice\n⑤ L2 (tool_result_persist): If LLM used tools, scan tool output via Purview processContent(downloadText) → redact if BLOCKED\n⑥ Response delivered to user via Telegram",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "groupIds": [],
      "roundness": null,
      "seed": 1200,
      "version": 1,
      "versionNonce": 1200,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "Message Flow:\n① User sends message via Telegram → Gateway receives it\n② L3 (message_received): Purview processContent(uploadText) → logs BLOCKED or ALLOWED (audit only, cannot block delivery)\n③ L1 (before_agent_start): DLP security policy injected into LLM system context (\"never output credit cards, SSNs...\")\n④ LLM processes message with DLP policy active → refuses to echo sensitive data → responds with [Agent Warden DLP] notice\n⑤ L2 (tool_result_persist): If LLM used tools, scan tool output via Purview processContent(downloadText) → redact if BLOCKED\n⑥ Response delivered to user via Telegram",
      "lineHeight": 1.25,
      "baseline": 124
    }
  ],
